# ─────────────────────────────────────────────
# GBC Analytics Dashboard — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# ── RetailCRM ──────────────────────────────
# Demo account: https://retailcrm.ru/demo
RETAIL_CRM_URL=https://your-domain.retailcrm.ru
RETAIL_CRM_API_KEY=your_retailcrm_api_key_here

# ── Supabase ───────────────────────────────
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Telegram Bot ───────────────────────────
# Obtain from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── App ────────────────────────────────────
# Threshold in KZT for Telegram notifications
ORDER_ALERT_THRESHOLD=50000
# Your deployed Vercel URL (for webhook registration)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
